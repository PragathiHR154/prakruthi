3. Linear search 
public class LinearSearch {
    public static int search(int arr[], int key) {
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == key) {
                return i; // element found
            }
        }
        return -1; // not found
    }
    public static void main(String[] args) {
        int arr[] = {10, 20, 30, 40, 50};
        int key = 30;
        int result = search(arr, key);
        if (result != -1)
            System.out.println("Element found at index: " + result);
        else
            System.out.println("Element not found");
    }
}
__________

import static org.junit.Assert.*;
import org.junit.Test;
public class LinearSearchTest {
    @Test
    public void testElementFound() {
        int arr[] = {10, 20, 30, 40, 50};
        int result = LinearSearch.search(arr, 30);
        assertEquals(2, result);
    }
    @Test
    public void testElementNotFound() {
        int arr[] = {10, 20, 30, 40, 50};
        int result = LinearSearch.search(arr, 99);
        assertEquals(-1, result);
    }
}


4. Compare 3 numbers and print highest number among three 
public class MaxNumber {
    public int findMax(int a, int b, int c) {
        int max = a;
        if (b > max) {
            max = b;
        }
        if (c > max) {
            max = c;
        }
        return max;
    }
    public static void main(String[] args) {
        MaxNumber m = new MaxNumber();
        int result = m.findMax(10, 25, 15);
        System.out.println("Highest number is: " + result);
    }
}
_____

import static org.junit.Assert.*;
import org.junit.Test;

public class MaxNumberTest {

    MaxNumber m = new MaxNumber();

    @Test
    public void testMax1() {
        assertEquals(25, m.findMax(10, 25, 15));
    }

    @Test
    public void testMax2() {
        assertEquals(50, m.findMax(50, 20, 30));
    }

    @Test
    public void testMax3() {
        assertEquals(40, m.findMax(10, 20, 40));
    }
}


5. Bank account ( balance, deposit n withdrawal)
public class BankAccount {
    double balance;
    public BankAccount(double balance) {
        this.balance = balance;
    }
    public void deposit(double amount) {
        balance += amount;
    }
    public void withdraw(double amount) {
        balance -= amount;
    }
    public double getBalance() {
        return balance;
    }
}
__________________

import static org.junit.Assert.*;
import org.junit.Test;

public class BankAccountTest {

    @Test
    public void testDeposit() {
        BankAccount b = new BankAccount(1000);
        b.deposit(500);
        assertEquals(1500, b.getBalance(), 0.0);
    }

    @Test
    public void testWithdraw() {
        BankAccount b = new BankAccount(1000);
        b.withdraw(200);
        assertEquals(800, b.getBalance(), 0.0);
    }
}

